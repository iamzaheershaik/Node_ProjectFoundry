<%- include('../partials/head') %>
    <%- include('../partials/layout_open') %>

        <!-- Bread crumb -->
        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-5 align-self-center">
                    <h4 class="page-title">Edit Category</h4>
                    <div class="d-flex align-items-center">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/category/view">Categories</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Edit Category</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
        <!-- End Breadcrumb -->

        <!-- Container fluid -->
        <div class="container-fluid">

            <%- include('../partials/flash_messages') %>

                <!-- Row -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h4 class="card-title">Edit Category</h4>
                                <h6 class="card-subtitle mb-3 text-muted">Update the category
                                    details below.</h6>
                                <hr>

                                <!-- Current Category Image Preview -->
                                <% if (typeof category !=='undefined' && category.categoryImage) { %>
                                    <div class="text-center mb-4">
                                        <img src="<%= category.categoryImage %>" alt="<%= category.name %>"
                                            class="rounded" width="200" height="120"
                                            style="object-fit: cover; border: 3px solid #7460ee;">
                                        <p class="mt-2 text-muted"><small>Current category image</small>
                                        </p>
                                    </div>
                                    <% } %>

                                        <form action="/category/edit/<%= category._id %>" method="POST"
                                            enctype="multipart/form-data" class="mt-4">

                                            <div class="row">
                                                <!-- Category Name -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="categoryName">Category Name <span
                                                                class="text-danger">*</span></label>
                                                        <div class="input-group">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text"><i
                                                                        class="fas fa-tag"></i></span>
                                                            </div>
                                                            <input type="text" class="form-control" id="categoryName"
                                                                name="name" value="<%= category.name %>"
                                                                placeholder="Enter category name" required>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Category Image -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="categoryImage">Category Image</label>
                                                        <div class="custom-file">
                                                            <input type="file" class="custom-file-input"
                                                                id="categoryImage" name="categoryImage"
                                                                accept="image/*">
                                                            <label class="custom-file-label" for="categoryImage">Choose
                                                                new
                                                                file...</label>
                                                        </div>
                                                        <small class="form-text text-muted">Leave
                                                            empty to keep the
                                                            current image. Max: 2MB.</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">
                                                <!-- Description -->
                                                <div class="col-md-12">
                                                    <div class="form-group">
                                                        <label for="categoryDescription">Description</label>
                                                        <textarea class="form-control" id="categoryDescription"
                                                            name="description" rows="4"
                                                            placeholder="Write category description here..."><%= category.description %></textarea>
                                                    </div>
                                                </div>
                                            </div>

                                            <hr>

                                            <!-- Submit Buttons -->
                                            <div class="form-group mb-0">
                                                <button type="submit" class="btn btn-warning mr-2">
                                                    <i class="fas fa-save mr-1"></i> Update Category
                                                </button>
                                                <a href="/category/view/<%= category._id %>" class="btn btn-info mr-2">
                                                    <i class="fas fa-eye mr-1"></i> View Category
                                                </a>
                                                <a href="/category/view" class="btn btn-secondary">
                                                    <i class="fas fa-arrow-left mr-1"></i> Cancel
                                                </a>
                                            </div>

                                        </form>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Row -->

        </div>
        <!-- End Container fluid -->

        <!-- Custom file input label update script -->
        <script>
            document.querySelectorAll('.custom-file-input').forEach(function (input) {
                input.addEventListener('change', function (e) {
                    var fileName = e.target.files[0] ? e.target.files[0].name : 'Choose new file...';
                    var label = e.target.nextElementSibling;
                    label.textContent = fileName;
                });
            });
        </script>
        <%- include('../partials/layout_close') %>