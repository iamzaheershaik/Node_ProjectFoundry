<%- include('../partials/head') %>
    <%- include('../partials/layout_open') %>

        <!-- Bread crumb -->
        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-5 align-self-center">
                    <h4 class="page-title">View Categories</h4>
                    <div class="d-flex align-items-center">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item active" aria-current="page">View Categories</li>
                            </ol>
                        </nav>
                    </div>
                </div>
                <div class="col-7 align-self-center text-right">
                    <a href="/category/add" class="btn btn-primary">
                        <i class="fas fa-plus-circle mr-1"></i> Add New Category
                    </a>
                </div>
            </div>
        </div>
        <!-- End Breadcrumb -->

        <!-- Container fluid -->
        <div class="container-fluid">

            <%- include('../partials/flash_messages') %>

                <!-- Row -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h4 class="card-title">All Categories</h4>
                                <h6 class="card-subtitle mb-3 text-muted">List of all categories in
                                    the system.</h6>

                                <!-- Search Bar -->
                                <form method="GET" action="/category/view" class="mb-3">
                                    <div class="input-group">
                                        <input type="text" name="search" class="form-control"
                                            placeholder="Search by name or description..."
                                            value="<%= typeof search !== 'undefined' ? search : '' %>">
                                        <div class="input-group-append">
                                            <button type="submit" class="btn btn-primary"><i
                                                    class="fas fa-search mr-1"></i>Search</button>
                                            <% if (typeof search !=='undefined' && search) { %>
                                                <a href="/category/view" class="btn btn-secondary"><i
                                                        class="fas fa-times mr-1"></i>Clear</a>
                                                <% } %>
                                        </div>
                                    </div>
                                </form>
                                <!-- End Search Bar -->

                                <div class="table-responsive">
                                    <table class="table table-bordered table-striped">
                                        <thead class="thead-light">
                                            <tr>
                                                <th>#</th>
                                                <th>Image</th>
                                                <th>Name</th>
                                                <th>Description</th>
                                                <th>Subcategories</th>
                                                <th>Created At</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (typeof categories !=='undefined' && categories.length> 0) {
                                                %>
                                                <% categories.forEach(function(category, index) { %>
                                                    <tr>
                                                        <td>
                                                            <%= index + 1 %>
                                                        </td>
                                                        <td>
                                                            <% if (category.categoryImage) { %>
                                                                <img src="<%= category.categoryImage %>"
                                                                    alt="<%= category.name %>" class="rounded"
                                                                    width="60" height="40" style="object-fit: cover;">
                                                                <% } else { %>
                                                                    <img src="/assets/images/big/img1.jpg" alt="Default"
                                                                        class="rounded" width="60" height="40"
                                                                        style="object-fit: cover;">
                                                                    <% } %>
                                                        </td>
                                                        <td>
                                                            <strong>
                                                                <%= category.name %>
                                                            </strong>
                                                        </td>
                                                        <td>
                                                            <%= category.description ? category.description.substring(0,
                                                                50) + (category.description.length> 50 ? '...' : '') :
                                                                'N/A' %>
                                                        </td>
                                                        <td>
                                                            <span class="badge badge-pill badge-primary"
                                                                style="font-size: 13px;">
                                                                <%= category.subcategoryCount || 0 %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <%= category.createdAt ? new
                                                                Date(category.createdAt).toLocaleDateString() : 'N/A' %>
                                                        </td>
                                                        <td>
                                                            <a href="/category/view/<%= category._id %>"
                                                                class="btn btn-sm btn-info mr-1" title="View">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                            <a href="/category/edit/<%= category._id %>"
                                                                class="btn btn-sm btn-warning mr-1" title="Edit">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                            <a href="/category/delete/<%= category._id %>"
                                                                class="btn btn-sm btn-danger" title="Delete"
                                                                onclick="return confirm('Are you sure you want to delete this category?')">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="7" class="text-center text-muted py-4">
                                                                    <i
                                                                        class="mdi mdi-folder-remove-outline font-24 d-block mb-2"></i>
                                                                    <% if (typeof search !=='undefined' && search) { %>
                                                                        No categories found matching
                                                                        "<strong>
                                                                            <%= search %>
                                                                        </strong>". <a href="/category/view">View
                                                                            all
                                                                            categories</a>.
                                                                        <% } else { %>
                                                                            No categories found. <a
                                                                                href="/category/add">Create
                                                                                one now</a>.
                                                                            <% } %>
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Row -->

        </div>
        <!-- End Container fluid -->
        <%- include('../partials/layout_close') %>