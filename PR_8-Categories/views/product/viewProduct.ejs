<!DOCTYPE html>
<html dir="ltr" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Blog Admin Panel">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon.png">
    <title>Blog Admin Panel</title>
    <link href="/assets/libs/toastr/build/toastr.min.css" rel="stylesheet">
    <link href="/dist/css/style.min.css" rel="stylesheet">
</head>

<body>
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>
    <div id="main-wrapper" data-layout="vertical" data-navbarbg="skin5" data-sidebartype="full"
        data-sidebar-position="absolute" data-header-position="absolute" data-boxed-layout="full">
        <%- include('../header') %>
            <div class="page-wrapper">

                <!-- Bread crumb -->
                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">View Products</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">View Products</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                        <div class="col-7 align-self-center text-right">
                            <a href="/product/add" class="btn btn-primary">
                                <i class="fas fa-plus-circle mr-1"></i> Add New Product
                            </a>
                        </div>
                    </div>
                </div>
                <!-- End Breadcrumb -->

                <!-- Container fluid -->
                <div class="container-fluid">

                    <!-- Flash Messages -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <%= success %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                        </div>
                        <% } %>
                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <%= error %>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                </div>
                                <% } %>

                                    <!-- Search Bar -->
                                    <div class="row mb-3">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body py-3">
                                                    <form method="GET" action="/product/view">
                                                        <div class="input-group">
                                                            <input type="text" name="search" class="form-control"
                                                                placeholder="Search by name or description..."
                                                                value="<%= typeof search !== 'undefined' ? search : '' %>">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-primary"><i
                                                                        class="fas fa-search mr-1"></i>Search</button>
                                                                <% if (typeof search !=='undefined' && search) { %>
                                                                    <a href="/product/view"
                                                                        class="btn btn-secondary"><i
                                                                            class="fas fa-times mr-1"></i>Clear</a>
                                                                    <% } %>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- End Search Bar -->

                                    <!-- Card Layout for Products -->
                                    <div class="row">
                                        <% if (typeof products !=='undefined' && products.length> 0) { %>
                                            <% products.forEach(function(product) { %>
                                                <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                                                    <div class="card h-100"
                                                        style="border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: transform 0.2s, box-shadow 0.2s;">
                                                        <!-- Card Image -->
                                                        <div
                                                            style="height: 200px; overflow: hidden; background: #f6f7fb; display: flex; align-items: center; justify-content: center;">
                                                            <% if (product.productImage) { %>
                                                                <img src="<%= product.productImage %>"
                                                                    alt="<%= product.name %>"
                                                                    style="width: 100%; height: 100%; object-fit: contain; padding: 10px;">
                                                                <% } else { %>
                                                                    <div style="text-align: center; color: #b0bec5;">
                                                                        <i class="mdi mdi-image-off" style="font-size: 48px;"></i>
                                                                        <p style="margin: 5px 0 0; font-size: 12px;">No Image</p>
                                                                    </div>
                                                                    <% } %>
                                                        </div>

                                                        <!-- Card Body -->
                                                        <div class="card-body">
                                                            <h5 class="card-title font-weight-bold mb-2">
                                                                <i
                                                                    class="mdi mdi-package-variant mr-1 text-primary"></i>
                                                                <%= product.name %>
                                                            </h5>

                                                            <!-- Category Chain Badges -->
                                                            <div class="mb-2">
                                                                <% if (product.category) { %>
                                                                    <span class="badge badge-info mr-1"
                                                                        style="font-size: 11px;">
                                                                        <i class="mdi mdi-folder mr-1"></i>
                                                                        <%= product.category.name %>
                                                                    </span>
                                                                    <% } %>
                                                                <% if (product.subcategory) { %>
                                                                    <span class="badge badge-primary mr-1"
                                                                        style="font-size: 11px;">
                                                                        <i class="mdi mdi-folder-star mr-1"></i>
                                                                        <%= product.subcategory.name %>
                                                                    </span>
                                                                    <% } %>
                                                                <% if (product.extracategory) { %>
                                                                    <span class="badge badge-secondary"
                                                                        style="font-size: 11px;">
                                                                        <i class="mdi mdi-folder-multiple-outline mr-1"></i>
                                                                        <%= product.extracategory.name %>
                                                                    </span>
                                                                    <% } %>
                                                            </div>

                                                            <!-- Price & Quantity -->
                                                            <div
                                                                class="d-flex justify-content-between align-items-center mb-2">
                                                                <h5 class="mb-0 text-success font-weight-bold">
                                                                    ₹<%= product.price || 0 %>
                                                                </h5>
                                                                <% if (product.quantity> 0) { %>
                                                                    <span class="badge badge-success"
                                                                        style="font-size: 11px;">
                                                                        <i class="fas fa-check-circle mr-1"></i>In
                                                                        Stock: <%= product.quantity %>
                                                                    </span>
                                                                    <% } else { %>
                                                                        <span class="badge badge-danger"
                                                                            style="font-size: 11px;">
                                                                            <i class="fas fa-times-circle mr-1"></i>Out
                                                                            of Stock
                                                                        </span>
                                                                        <% } %>
                                                            </div>

                                                            <p class="card-text text-muted" style="font-size: 13px;">
                                                                <%= product.description ? product.description.substring(0,
                                                                    80) + (product.description.length> 80 ? '...' : '') :
                                                                    'No description provided' %>
                                                            </p>

                                                            <small class="text-muted">
                                                                <i class="fas fa-calendar-alt mr-1"></i>
                                                                <%= product.createdAt ? new
                                                                    Date(product.createdAt).toLocaleDateString() : 'N/A'
                                                                    %>
                                                            </small>
                                                        </div>

                                                        <!-- Card Footer with Actions -->
                                                        <div class="card-footer bg-white border-top"
                                                            style="padding: 12px 20px;">
                                                            <div class="d-flex justify-content-between">
                                                                <a href="/product/view/<%= product._id %>"
                                                                    class="btn btn-sm btn-info" title="View">
                                                                    <i class="fas fa-eye mr-1"></i> View
                                                                </a>
                                                                <a href="/product/edit/<%= product._id %>"
                                                                    class="btn btn-sm btn-warning" title="Edit">
                                                                    <i class="fas fa-edit mr-1"></i> Edit
                                                                </a>
                                                                <a href="/product/delete/<%= product._id %>"
                                                                    class="btn btn-sm btn-danger" title="Delete"
                                                                    onclick="return confirm('Are you sure you want to delete this product?')">
                                                                    <i class="fas fa-trash-alt mr-1"></i> Delete
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% } else { %>
                                                        <div class="col-12">
                                                            <div class="card">
                                                                <div class="card-body text-center text-muted py-5">
                                                                    <i
                                                                        class="mdi mdi-package-variant-remove font-24 d-block mb-2"></i>
                                                                    <% if (typeof search !=='undefined' && search) { %>
                                                                        No products found matching
                                                                        "<strong>
                                                                            <%= search %>
                                                                        </strong>".
                                                                        <a href="/product/view">View all products</a>.
                                                                        <% } else { %>
                                                                            No products found.
                                                                            <a href="/product/add">Create one now</a>.
                                                                            <% } %>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <% } %>
                                    </div>
                                    <!-- End Card Layout -->

                </div>
                <!-- End Container fluid -->
                <%- include('../footer') %>
            </div>
    </div>
    <script src="/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="/assets/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="/dist/js/app-style-switcher.js"></script>
    <script src="/dist/js/waves.js"></script>
    <script src="/dist/js/sidebarmenu.js"></script>
    <script src="/dist/js/custom.js"></script>
    <script src="/assets/libs/toastr/build/toastr.min.js"></script>

    <!-- Card hover effect -->
    <style>
        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
        }
    </style>
</body>

</html>
