<!DOCTYPE html>
<html dir="ltr" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Blog Admin Panel">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon.png">
    <title>Blog Admin Panel</title>
    <link href="/assets/libs/toastr/build/toastr.min.css" rel="stylesheet">
    <link href="/dist/css/style.min.css" rel="stylesheet">
</head>

<body>
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>
    <div id="main-wrapper" data-layout="vertical" data-navbarbg="skin5" data-sidebartype="full"
        data-sidebar-position="absolute" data-header-position="absolute" data-boxed-layout="full">
        <%- include('../header') %>
            <div class="page-wrapper">
                <!-- ============================================================== -->
                <!-- View Single Subcategory Page -->
                <!-- ============================================================== -->

                <!-- Bread crumb -->
                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">View Subcategory</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                        <li class="breadcrumb-item"><a href="/subcategory/view">Subcategories</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">View Subcategory</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Breadcrumb -->

                <!-- Container fluid -->
                <div class="container-fluid">

                    <!-- Flash Messages -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <%= success %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                        </div>
                        <% } %>
                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <%= error %>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                </div>
                                <% } %>

                                    <!-- Row -->
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <div>
                                                            <h4 class="card-title mb-0">Subcategory Details</h4>
                                                            <h6 class="card-subtitle mt-1 text-muted">Viewing
                                                                subcategory information.</h6>
                                                        </div>
                                                        <div>
                                                            <a href="/subcategory/edit/<%= subcategory._id %>"
                                                                class="btn btn-warning mr-1">
                                                                <i class="fas fa-edit mr-1"></i> Edit
                                                            </a>
                                                            <a href="/subcategory/delete/<%= subcategory._id %>"
                                                                class="btn btn-danger mr-1"
                                                                onclick="return confirm('Are you sure you want to delete this subcategory?')">
                                                                <i class="fas fa-trash-alt mr-1"></i> Delete
                                                            </a>
                                                            <a href="/subcategory/view" class="btn btn-secondary">
                                                                <i class="fas fa-arrow-left mr-1"></i> Back
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <hr>

                                                    <div class="row mt-4">
                                                        <!-- Subcategory Image -->
                                                        <div class="col-md-4 text-center">
                                                            <% if (subcategory.subcategoryImage) { %>
                                                                <img src="<%= subcategory.subcategoryImage %>"
                                                                    alt="<%= subcategory.name %>"
                                                                    class="rounded img-fluid"
                                                                    style="max-height: 250px; object-fit: cover; border: 3px solid #7460ee;">
                                                            <% } else { %>
                                                                <img src="/assets/images/big/img1.jpg" alt="Default"
                                                                    class="rounded img-fluid"
                                                                    style="max-height: 250px; object-fit: cover; border: 3px solid #7460ee;">
                                                            <% } %>
                                                        </div>

                                                        <!-- Subcategory Info -->
                                                        <div class="col-md-8">
                                                            <table class="table table-borderless">
                                                                <tbody>
                                                                    <tr>
                                                                        <th width="150"><i
                                                                                class="fas fa-tag mr-2 text-primary"></i>Name
                                                                        </th>
                                                                        <td><strong><%= subcategory.name %></strong>
                                                                        </td>
                                                                    </tr>
                                                                    <tr>
                                                                        <th><i
                                                                                class="fas fa-folder mr-2 text-primary"></i>Parent
                                                                            Category</th>
                                                                        <td>
                                                                            <span class="badge badge-primary badge-pill"
                                                                                style="font-size: 14px;">
                                                                                <%= subcategory.category ? subcategory.category.name : 'N/A' %>
                                                                            </span>
                                                                        </td>
                                                                    </tr>
                                                                    <tr>
                                                                        <th><i
                                                                                class="fas fa-align-left mr-2 text-primary"></i>Description
                                                                        </th>
                                                                        <td><%= subcategory.description || 'No description provided' %></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <th><i
                                                                                class="fas fa-calendar-alt mr-2 text-primary"></i>Created
                                                                            At</th>
                                                                        <td><%= subcategory.createdAt ? new Date(subcategory.createdAt).toLocaleDateString() : 'N/A' %></td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- End Row -->

                                    <!-- Related ExtraCategories -->
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <div>
                                                            <h4 class="card-title mb-0">
                                                                <i class="mdi mdi-folder-multiple-outline mr-1 text-primary"></i>
                                                                Related ExtraCategories
                                                            </h4>
                                                            <h6 class="card-subtitle mt-1 text-muted">
                                                                ExtraCategories under "<%= subcategory.name %>"
                                                            </h6>
                                                        </div>
                                                        <a href="/extracategory/add" class="btn btn-sm btn-primary">
                                                            <i class="fas fa-plus mr-1"></i> Add ExtraCategory
                                                        </a>
                                                    </div>

                                                    <div class="table-responsive">
                                                        <table class="table table-bordered table-striped">
                                                            <thead class="thead-light">
                                                                <tr>
                                                                    <th>#</th>
                                                                    <th>Image</th>
                                                                    <th>Name</th>
                                                                    <th>Description</th>
                                                                    <th>Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% if (typeof extracategories !== 'undefined' && extracategories.length > 0) { %>
                                                                    <% extracategories.forEach(function(extra, index) { %>
                                                                        <tr>
                                                                            <td><%= index + 1 %></td>
                                                                            <td>
                                                                                <% if (extra.extracategoryImage) { %>
                                                                                    <img src="<%= extra.extracategoryImage %>"
                                                                                        alt="<%= extra.name %>"
                                                                                        class="rounded" width="50"
                                                                                        height="35"
                                                                                        style="object-fit: cover;">
                                                                                <% } else { %>
                                                                                    <img src="/assets/images/big/img1.jpg"
                                                                                        alt="Default" class="rounded"
                                                                                        width="50" height="35"
                                                                                        style="object-fit: cover;">
                                                                                <% } %>
                                                                            </td>
                                                                            <td><strong><%= extra.name %></strong></td>
                                                                            <td><%= extra.description ? extra.description.substring(0, 60) + (extra.description.length > 60 ? '...' : '') : 'N/A' %></td>
                                                                            <td>
                                                                                <a href="/extracategory/view/<%= extra._id %>"
                                                                                    class="btn btn-sm btn-info mr-1"
                                                                                    title="View">
                                                                                    <i class="fas fa-eye"></i>
                                                                                </a>
                                                                                <a href="/extracategory/edit/<%= extra._id %>"
                                                                                    class="btn btn-sm btn-warning mr-1"
                                                                                    title="Edit">
                                                                                    <i class="fas fa-edit"></i>
                                                                                </a>
                                                                                <a href="/extracategory/delete/<%= extra._id %>"
                                                                                    class="btn btn-sm btn-danger"
                                                                                    title="Delete"
                                                                                    onclick="return confirm('Are you sure you want to delete this extra category?')">
                                                                                    <i class="fas fa-trash-alt"></i>
                                                                                </a>
                                                                            </td>
                                                                        </tr>
                                                                    <% }) %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="5"
                                                                            class="text-center text-muted py-3">
                                                                            <i class="mdi mdi-folder-remove-outline font-20 d-block mb-1"></i>
                                                                            No extra categories found for this subcategory.
                                                                            <a href="/extracategory/add">Create one now</a>.
                                                                        </td>
                                                                    </tr>
                                                                <% } %>
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- End Related ExtraCategories -->

                </div>
                <!-- End Container fluid -->
                <%- include('../footer') %>
            </div>
    </div>
    <script src="/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="/assets/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="/dist/js/app-style-switcher.js"></script>
    <script src="/dist/js/waves.js"></script>
    <script src="/dist/js/sidebarmenu.js"></script>
    <script src="/dist/js/custom.js"></script>
    <script src="/assets/libs/toastr/build/toastr.min.js"></script>
</body>

</html>
