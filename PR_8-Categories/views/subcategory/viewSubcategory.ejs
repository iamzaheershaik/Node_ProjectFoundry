<!DOCTYPE html>
<html dir="ltr" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Blog Admin Panel">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon.png">
    <title>Blog Admin Panel</title>
    <link href="/assets/libs/toastr/build/toastr.min.css" rel="stylesheet">
    <link href="/dist/css/style.min.css" rel="stylesheet">
</head>

<body>
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>
    <div id="main-wrapper" data-layout="vertical" data-navbarbg="skin5" data-sidebartype="full"
        data-sidebar-position="absolute" data-header-position="absolute" data-boxed-layout="full">
        <%- include('../header') %>
            <div class="page-wrapper">
                <!-- ============================================================== -->
                <!-- View All Subcategories Page -->
                <!-- ============================================================== -->

                <!-- Bread crumb -->
                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">View Subcategories</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">View Subcategories</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                        <div class="col-7 align-self-center text-right">
                            <a href="/subcategory/add" class="btn btn-primary">
                                <i class="fas fa-plus-circle mr-1"></i> Add New Subcategory
                            </a>
                        </div>
                    </div>
                </div>
                <!-- End Breadcrumb -->

                <!-- Container fluid -->
                <div class="container-fluid">

                    <!-- Flash Messages -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <%= success %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                        </div>
                        <% } %>
                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <%= error %>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                </div>
                                <% } %>

                                    <!-- Row -->
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body">
                                                    <h4 class="card-title">All Subcategories</h4>
                                                    <h6 class="card-subtitle mb-3 text-muted">List of all subcategories
                                                        in the system.</h6>

                                                    <!-- Search Bar -->
                                                    <form method="GET" action="/subcategory/view" class="mb-3">
                                                        <div class="input-group">
                                                            <input type="text" name="search" class="form-control"
                                                                placeholder="Search by name or description..."
                                                                value="<%= typeof search !== 'undefined' ? search : '' %>">
                                                            <div class="input-group-append">
                                                                <button type="submit" class="btn btn-primary"><i
                                                                        class="fas fa-search mr-1"></i>Search</button>
                                                                <% if (typeof search !=='undefined' && search) { %>
                                                                    <a href="/subcategory/view"
                                                                        class="btn btn-secondary"><i
                                                                            class="fas fa-times mr-1"></i>Clear</a>
                                                                    <% } %>
                                                            </div>
                                                        </div>
                                                    </form>
                                                    <!-- End Search Bar -->

                                                    <div class="table-responsive">
                                                        <table class="table table-bordered table-striped">
                                                            <thead class="thead-light">
                                                                <tr>
                                                                    <th>#</th>
                                                                    <th>Image</th>
                                                                    <th>Subcategory Name</th>
                                                                    <th>Parent Category</th>
                                                                    <th>Description</th>
                                                                    <th>Created At</th>
                                                                    <th>Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% if (typeof subcategories !=='undefined' && subcategories.length > 0) { %>
                                                                    <% subcategories.forEach(function(sub, index) { %>
                                                                        <tr>
                                                                            <td><%= index + 1 %></td>
                                                                            <td>
                                                                                <% if (sub.subcategoryImage) { %>
                                                                                    <img src="<%= sub.subcategoryImage %>"
                                                                                        alt="<%= sub.name %>"
                                                                                        class="rounded" width="60"
                                                                                        height="40"
                                                                                        style="object-fit: cover;">
                                                                                <% } else { %>
                                                                                    <img src="/assets/images/big/img1.jpg"
                                                                                        alt="Default" class="rounded"
                                                                                        width="60" height="40"
                                                                                        style="object-fit: cover;">
                                                                                <% } %>
                                                                            </td>
                                                                            <td><strong><%= sub.name %></strong></td>
                                                                            <td>
                                                                                <span class="badge badge-primary">
                                                                                    <%= sub.category ? sub.category.name : 'N/A' %>
                                                                                </span>
                                                                            </td>
                                                                            <td>
                                                                                <%= sub.description ? sub.description.substring(0, 50) + (sub.description.length > 50 ? '...' : '') : 'N/A' %>
                                                                            </td>
                                                                            <td>
                                                                                <%= sub.createdAt ? new Date(sub.createdAt).toLocaleDateString() : 'N/A' %>
                                                                            </td>
                                                                            <td>
                                                                                <a href="/subcategory/view/<%= sub._id %>"
                                                                                    class="btn btn-sm btn-info mr-1"
                                                                                    title="View">
                                                                                    <i class="fas fa-eye"></i>
                                                                                </a>
                                                                                <a href="/subcategory/edit/<%= sub._id %>"
                                                                                    class="btn btn-sm btn-warning mr-1"
                                                                                    title="Edit">
                                                                                    <i class="fas fa-edit"></i>
                                                                                </a>
                                                                                <a href="/subcategory/delete/<%= sub._id %>"
                                                                                    class="btn btn-sm btn-danger"
                                                                                    title="Delete"
                                                                                    onclick="return confirm('Are you sure you want to delete this subcategory?')">
                                                                                    <i class="fas fa-trash-alt"></i>
                                                                                </a>
                                                                            </td>
                                                                        </tr>
                                                                    <% }) %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="7"
                                                                            class="text-center text-muted py-4">
                                                                            <i class="mdi mdi-folder-remove-outline font-24 d-block mb-2"></i>
                                                                            <% if (typeof search !=='undefined' && search) { %>
                                                                                No subcategories found matching
                                                                                "<strong><%= search %></strong>".
                                                                                <a href="/subcategory/view">View all subcategories</a>.
                                                                            <% } else { %>
                                                                                No subcategories found.
                                                                                <a href="/subcategory/add">Create one now</a>.
                                                                            <% } %>
                                                                        </td>
                                                                    </tr>
                                                                <% } %>
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- End Row -->

                </div>
                <!-- End Container fluid -->
                <%- include('../footer') %>
            </div>
    </div>
    <script src="/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="/assets/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="/dist/js/app-style-switcher.js"></script>
    <script src="/dist/js/waves.js"></script>
    <script src="/dist/js/sidebarmenu.js"></script>
    <script src="/dist/js/custom.js"></script>
    <script src="/assets/libs/toastr/build/toastr.min.js"></script>
</body>

</html>
