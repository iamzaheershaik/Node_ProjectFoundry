<%- include('../partials/head') %>
    <%- include('../partials/layout_open') %>

        <!-- Bread crumb -->
        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-5 align-self-center">
                    <h4 class="page-title">Edit Subcategory</h4>
                    <div class="d-flex align-items-center">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/subcategory/view">Subcategories</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Edit Subcategory</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
        <!-- End Breadcrumb -->

        <!-- Container fluid -->
        <div class="container-fluid">

            <%- include('../partials/flash_messages') %>

                <!-- Row -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h4 class="card-title">Edit Subcategory</h4>
                                <h6 class="card-subtitle mb-3 text-muted">Update the subcategory
                                    details below.</h6>
                                <hr>

                                <!-- Current Image Preview -->
                                <% if (typeof subcategory !=='undefined' && subcategory.subcategoryImage) { %>
                                    <div class="text-center mb-4">
                                        <img src="<%= subcategory.subcategoryImage %>" alt="<%= subcategory.name %>"
                                            class="rounded" width="200" height="120"
                                            style="object-fit: cover; border: 3px solid #7460ee;">
                                        <p class="mt-2 text-muted"><small>Current subcategory
                                                image</small></p>
                                    </div>
                                    <% } %>

                                        <form action="/subcategory/edit/<%= subcategory._id %>" method="POST"
                                            enctype="multipart/form-data" class="mt-4">

                                            <div class="row">
                                                <!-- Parent Category -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="parentCategory">Parent Category <span
                                                                class="text-danger">*</span></label>
                                                        <div class="input-group">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text"><i
                                                                        class="fas fa-folder"></i></span>
                                                            </div>
                                                            <select class="form-control" id="parentCategory"
                                                                name="category" required>
                                                                <option value="" disabled>Select Parent
                                                                    Category</option>
                                                                <% if (typeof categories !=='undefined' &&
                                                                    categories.length> 0) { %>
                                                                    <% categories.forEach(function(cat) { %>
                                                                        <option value="<%= cat._id %>"
                                                                            <%=subcategory.category &&
                                                                            subcategory.category._id.toString()===cat._id.toString()
                                                                            ? 'selected' : '' %>><%= cat.name %>
                                                                        </option>
                                                                        <% }) %>
                                                                            <% } %>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Subcategory Name -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="subcategoryName">Subcategory Name <span
                                                                class="text-danger">*</span></label>
                                                        <div class="input-group">
                                                            <div class="input-group-prepend">
                                                                <span class="input-group-text"><i
                                                                        class="fas fa-tag"></i></span>
                                                            </div>
                                                            <input type="text" class="form-control" id="subcategoryName"
                                                                name="name" value="<%= subcategory.name %>"
                                                                placeholder="Enter subcategory name" required>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">
                                                <!-- Description -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="subcategoryDescription">Description</label>
                                                        <textarea class="form-control" id="subcategoryDescription"
                                                            name="description" rows="4"
                                                            placeholder="Write subcategory description here..."><%= subcategory.description %></textarea>
                                                    </div>
                                                </div>

                                                <!-- Subcategory Image -->
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label for="subcategoryImage">Subcategory
                                                            Image</label>
                                                        <div class="custom-file">
                                                            <input type="file" class="custom-file-input"
                                                                id="subcategoryImage" name="subcategoryImage"
                                                                accept="image/*">
                                                            <label class="custom-file-label"
                                                                for="subcategoryImage">Choose new
                                                                file...</label>
                                                        </div>
                                                        <small class="form-text text-muted">Leave empty to
                                                            keep the current image. Max: 2MB.</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <hr>

                                            <!-- Submit Buttons -->
                                            <div class="form-group mb-0">
                                                <button type="submit" class="btn btn-warning mr-2">
                                                    <i class="fas fa-save mr-1"></i> Update Subcategory
                                                </button>
                                                <a href="/subcategory/view/<%= subcategory._id %>"
                                                    class="btn btn-info mr-2">
                                                    <i class="fas fa-eye mr-1"></i> View Subcategory
                                                </a>
                                                <a href="/subcategory/view" class="btn btn-secondary">
                                                    <i class="fas fa-arrow-left mr-1"></i> Cancel
                                                </a>
                                            </div>

                                        </form>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Row -->

        </div>
        <!-- End Container fluid -->

        <!-- Custom file input label update script -->
        <script>
            document.querySelectorAll('.custom-file-input').forEach(function (input) {
                input.addEventListener('change', function (e) {
                    var fileName = e.target.files[0] ? e.target.files[0].name : 'Choose new file...';
                    var label = e.target.nextElementSibling;
                    label.textContent = fileName;
                });
            });
        </script>
        <%- include('../partials/layout_close') %>