<!DOCTYPE html>
<html dir="ltr" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Category Admin Panel">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon.png">
    <title>Edit Category - Admin Panel</title>
    <link href="/assets/libs/toastr/build/toastr.min.css" rel="stylesheet">
    <link href="/dist/css/style.min.css" rel="stylesheet">
</head>

<body>
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>
    <div id="main-wrapper" data-layout="vertical" data-navbarbg="skin5" data-sidebartype="full"
        data-sidebar-position="absolute" data-header-position="absolute" data-boxed-layout="full">
        <%- include('../header') %>
            <div class="page-wrapper">
                <!-- ============================================================== -->
                <!-- Edit Category Page -->
                <!-- ============================================================== -->

                <!-- Bread crumb -->
                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">Edit Category</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                        <li class="breadcrumb-item"><a href="/category/view-category">Categories</a>
                                        </li>
                                        <li class="breadcrumb-item active" aria-current="page">Edit Category</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Breadcrumb -->

                <!-- Container fluid -->
                <div class="container-fluid">

                    <!-- Flash Messages -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <%= success %>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                        </div>
                        <% } %>
                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <%= error %>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                </div>
                                <% } %>

                                    <!-- Row -->
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body">
                                                    <h4 class="card-title">Edit Category</h4>
                                                    <h6 class="card-subtitle mb-3 text-muted">Update the category
                                                        details below.</h6>
                                                    <hr>

                                                    <!-- Current Category Image Preview -->
                                                    <% if (typeof category !=='undefined' && category.categoryImage) {
                                                        %>
                                                        <div class="text-center mb-4">
                                                            <img src="<%= category.categoryImage %>"
                                                                alt="<%= category.category %>" class="rounded"
                                                                width="200" height="120"
                                                                style="object-fit: cover; border: 3px solid #7460ee;">
                                                            <p class="mt-2 text-muted"><small>Current category
                                                                    image</small>
                                                            </p>
                                                        </div>
                                                        <% } %>

                                                            <form action="/category/edit-category/<%= category._id %>"
                                                                method="POST" enctype="multipart/form-data"
                                                                class="mt-4">

                                                                <div class="row">
                                                                    <!-- Category Name -->
                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label for="categoryName">Category Name
                                                                                <span
                                                                                    class="text-danger">*</span></label>
                                                                            <div class="input-group">
                                                                                <div class="input-group-prepend">
                                                                                    <span class="input-group-text"><i
                                                                                            class="fas fa-tag"></i></span>
                                                                                </div>
                                                                                <select class="form-control"
                                                                                    id="categoryName" name="category"
                                                                                    required>
                                                                                    <option value="" disabled>Select
                                                                                        Category</option>
                                                                                    <option value="Electronics"
                                                                                        <%=category.category==='Electronics'
                                                                                        ? 'selected' : '' %>>Electronics
                                                                                    </option>
                                                                                    <option value="Furniture"
                                                                                        <%=category.category==='Furniture'
                                                                                        ? 'selected' : '' %>>Furniture
                                                                                    </option>
                                                                                    <option value="Clothing"
                                                                                        <%=category.category==='Clothing'
                                                                                        ? 'selected' : '' %>>Clothing
                                                                                    </option>
                                                                                    <option value="Footwear"
                                                                                        <%=category.category==='Footwear'
                                                                                        ? 'selected' : '' %>>Footwear
                                                                                    </option>
                                                                                    <option value="Groceries"
                                                                                        <%=category.category==='Groceries'
                                                                                        ? 'selected' : '' %>>Groceries
                                                                                    </option>
                                                                                    <option
                                                                                        value="Beauty & Personal Care"
                                                                                        <%=category.category==='Beauty & Personal Care'
                                                                                        ? 'selected' : '' %>>Beauty &
                                                                                        Personal Care</option>
                                                                                    <option value="Home & Kitchen"
                                                                                        <%=category.category==='Home & Kitchen'
                                                                                        ? 'selected' : '' %>>Home &
                                                                                        Kitchen</option>
                                                                                    <option value="Books"
                                                                                        <%=category.category==='Books'
                                                                                        ? 'selected' : '' %>>Books
                                                                                    </option>
                                                                                    <option value="Toys & Games"
                                                                                        <%=category.category==='Toys & Games'
                                                                                        ? 'selected' : '' %>>Toys &
                                                                                        Games</option>
                                                                                    <option value="Sports & Fitness"
                                                                                        <%=category.category==='Sports & Fitness'
                                                                                        ? 'selected' : '' %>>Sports &
                                                                                        Fitness</option>
                                                                                </select>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Category Image -->
                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label for="categoryImage">Category
                                                                                Image</label>
                                                                            <div class="custom-file">
                                                                                <input type="file"
                                                                                    class="custom-file-input"
                                                                                    id="categoryImage"
                                                                                    name="categoryImage"
                                                                                    accept="image/*">
                                                                                <label class="custom-file-label"
                                                                                    for="categoryImage">Choose new
                                                                                    file...</label>
                                                                            </div>
                                                                            <small class="form-text text-muted">Leave
                                                                                empty to keep the
                                                                                current image. Max: 2MB.</small>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <hr>

                                                                <!-- Submit Buttons -->
                                                                <div class="form-group mb-0">
                                                                    <button type="submit" class="btn btn-warning mr-2">
                                                                        <i class="fas fa-save mr-1"></i> Update Category
                                                                    </button>
                                                                    <a href="/category/view-category"
                                                                        class="btn btn-secondary">
                                                                        <i class="fas fa-arrow-left mr-1"></i> Cancel
                                                                    </a>
                                                                </div>

                                                            </form>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- End Row -->

                </div>
                <!-- End Container fluid -->

                <!-- Custom file input label update script -->
                <script>
                    document.querySelectorAll('.custom-file-input').forEach(function (input) {
                        input.addEventListener('change', function (e) {
                            var fileName = e.target.files[0] ? e.target.files[0].name : 'Choose new file...';
                            var label = e.target.nextElementSibling;
                            label.textContent = fileName;
                        });
                    });
                </script>
                <%- include('../footer') %>
            </div>
    </div>
    <script src="/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="/assets/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="/dist/js/app-style-switcher.js"></script>
    <script src="/dist/js/waves.js"></script>
    <script src="/dist/js/sidebarmenu.js"></script>
    <script src="/dist/js/custom.js"></script>
    <script src="/assets/libs/toastr/build/toastr.min.js"></script>
</body>

</html>